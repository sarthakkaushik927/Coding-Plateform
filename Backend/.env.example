NODE_ENV=production
PORT=5000
MONGODB_URI=mongodb+srv://username:password@cluster.example.net/coding-platform
JWT_SECRET=replace-with-a-long-random-secret

# Comma-separated frontend origins for cross-origin deployments.
# Leave empty only when the frontend is served from the same origin as the API.
CORS_ORIGIN=https://your-frontend-domain.com

# Use either EMAIL_SERVICE for providers like gmail, or SMTP_* for custom SMTP.
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-email-app-password
EMAIL_FROM=your-email@example.com
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
